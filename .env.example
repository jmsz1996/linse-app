# linse — copy to .env and fill in the values below.
#   cp .env.example .env
# Generate each secret with:  openssl rand -base64 32

# --- required: secrets ---
POSTGRES_PASSWORD=change-me-to-a-long-random-string
AUTH_SECRET=                  # openssl rand -base64 32  (host login sessions)
LINSE_SECRET=                 # openssl rand -base64 32  (signs guest sessions + event password gate)

# --- required: bootstrap host admin ---
# A single host account is created (or its password rotated) on every boot from these.
HOST_ADMIN_EMAIL=host@example.com
HOST_ADMIN_PASSWORD=change-me # Make the password 8characters long!

# --- optional ---
LINSE_PORT=3000               # host port to expose the app on
LINSE_VERSION=latest          # published image tag to run (e.g. v0.1.0)
# Dev only: let the Next.js dev server serve JS to non-localhost devices
# (another machine on your LAN/VPN). Comma-separated IPs/hostnames.
# NEXTJS_DEV_ORIGINS=192.168.1.x

# --- internal (rarely changed) ---
# In-container upload path, backed by the linse_uploads named volume.
# To store photos at a host path instead, see runbook.md (compose.override.yml).
UPLOAD_DIR=/data/uploads
# In-container target for the host "Export originals" action, backed by the
# linse_exports named volume. To browse exports directly on the host, bind-mount
# it to a host path instead (see runbook.md).
EXPORT_DIR=/data/exports
